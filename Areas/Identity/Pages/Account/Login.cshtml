@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="container mt-5">
    <div class="row justify-content-center align-items-center">
        <div class="col-lg-10">
            <div class="row shadow rounded-4 overflow-hidden bg-white">
                <div class="col-md-6 d-none d-md-flex bg-dark text-white flex-column justify-content-center p-5">
                    <h2 class="fw-bold mb-3">Bienvenido de nuevo</h2>
                    <p class="mb-0">
                        Inicia sesión para acceder al sistema de farmacia y gestionar inventario, categorías, estantes y medicamentos.
                    </p>
                </div>

                <div class="col-md-6 p-5">
                    <div class="text-center mb-4">
                        <h1 class="fw-bold text-primary">Iniciar sesión</h1>
                        <p class="text-muted">Accede con tu correo y contraseña</p>
                    </div>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="correo@ejemplo.com" />
                            <label asp-for="Input.Email">Correo electrónico</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Contraseña" />
                            <label asp-for="Input.Password">Contraseña</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label asp-for="Input.RememberMe" class="form-check-label">
                                Recuérdame
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary mb-3">
                            Iniciar sesión
                        </button>

                        <div class="text-center">
                            <p class="mb-2">
                                <a id="forgot-password" asp-page="./ForgotPassword">¿Olvidaste tu contraseña?</a>
                            </p>
                            <p class="mb-2">
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Crear una cuenta nueva</a>
                            </p>
                            <p class="mb-0">
                                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Reenviar confirmación de correo</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}