@model Practica5Web3.Models.DashboardViewModel

@{
    ViewData["Title"] = "Inicio";
}

<div class="container-fluid py-5">

    @if (User.IsInRole("Administrador") || User.IsInRole("Farmaceutico"))
    {
        <!-- ENCABEZADO CON ICONO Y TITULO DESTACADO -->
        <div class="dashboard-header mb-5 p-4 rounded-4" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.9), rgba(118, 75, 162, 0.9)); backdrop-filter: blur(10px); border: 2px solid rgba(255,255,255,0.2);">
            <div class="row align-items-center">
                <div class="col-auto">
                    <div class="display-icon" style="width: 80px; height: 80px; background: rgba(255,255,255,0.2); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 2.5rem;">
                        <i class="bi bi-speedometer2 text-white"></i>
                    </div>
                </div>
                <div class="col">
                    <h1 class="display-5 text-white mb-2 fw-bold" style="text-shadow: 0 4px 8px rgba(0,0,0,0.2);">
                        <i class="bi bi-graph-up me-3"></i>Dashboard de Farmacia
                    </h1>
                    <p class="text-white-50 fs-5 mb-0">
                        <i class="bi bi-calendar3 me-2"></i>Resumen general del sistema • @DateTime.Now.ToString("dddd, dd MMMM yyyy")
                    </p>
                </div>
                <div class="col-auto">
                    <div style="background: rgba(255,255,255,0.1); padding: 1rem 1.5rem; border-radius: 12px; border-left: 3px solid #10b981;">
                        <small class="text-white-50">Estado del Sistema</small><br>
                        <strong class="text-success"><i class="bi bi-check-circle me-1"></i>En línea</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- TARJETAS DE MÉTRICAS PRINCIPALES CON DETALLES -->
        <div class="row g-4 mb-5">
            <!-- MEDICAMENTOS -->
            <div class="col-md-6 col-lg-3">
                <div class="card metric-card bg-primary-gradient border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden">
                    <div class="card-body text-center text-white">
                        <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                        <div class="icon-box mx-auto mb-3 position-relative">
                            <i class="bi bi-capsule"></i>
                        </div>
                        <h5 class="card-title mb-2 opacity-75">Medicamentos</h5>
                        <h2 class="fw-bold mb-3" style="font-size: 3rem;">@Model.TotalMedicamentos</h2>
                        <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                            <div class="progress-bar" style="width: @((Model.TotalMedicamentos / 100.0 * 100))%; background: rgba(255,255,255,0.6);"></div>
                        </div>
                        <small class="text-white-50 mt-2 d-block">Productos en stock</small>
                    </div>
                </div>
            </div>

            <!-- CATEGORÍAS -->
            <div class="col-md-6 col-lg-3">
                <div class="card metric-card bg-success-gradient border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden">
                    <div class="card-body text-center text-white">
                        <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                        <div class="icon-box mx-auto mb-3 position-relative">
                            <i class="bi bi-tags"></i>
                        </div>
                        <h5 class="card-title mb-2 opacity-75">Categorías</h5>
                        <h2 class="fw-bold mb-3" style="font-size: 3rem;">@Model.TotalCategorias</h2>
                        <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                            <div class="progress-bar" style="width: 100%; background: rgba(255,255,255,0.6);"></div>
                        </div>
                        <small class="text-white-50 mt-2 d-block">Clasificaciones</small>
                    </div>
                </div>
            </div>

            <!-- ESTANTES -->
            <div class="col-md-6 col-lg-3">
                <div class="card metric-card bg-info-gradient border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden">
                    <div class="card-body text-center text-white">
                        <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                        <div class="icon-box mx-auto mb-3 position-relative">
                            <i class="bi bi-inbox"></i>
                        </div>
                        <h5 class="card-title mb-2 opacity-75">Estantes</h5>
                        <h2 class="fw-bold mb-3" style="font-size: 3rem;">@Model.TotalEstantes</h2>
                        <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                            <div class="progress-bar" style="width: 100%; background: rgba(255,255,255,0.6);"></div>
                        </div>
                        <small class="text-white-50 mt-2 d-block">Ubicaciones</small>
                    </div>
                </div>
            </div>

            <!-- INVENTARIO -->
            <div class="col-md-6 col-lg-3">
                <div class="card metric-card bg-warning-gradient border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden">
                    <div class="card-body text-center text-white">
                        <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                        <div class="icon-box mx-auto mb-3 position-relative">
                            <i class="bi bi-cash-coin"></i>
                        </div>
                        <h5 class="card-title mb-2 opacity-75">Inventario</h5>
                        <h2 class="fw-bold mb-3" style="font-size: 2.5rem;">Bs @Model.TotalVentasEstimadas.ToString("N0")</h2>
                        <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                            <div class="progress-bar" style="width: 85%; background: rgba(255,255,255,0.6);"></div>
                        </div>
                        <small class="text-white-50 mt-2 d-block">Valor total</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- MÉTRICAS DE CLIENTES Y PEDIDOS (ADMIN) -->
        @if (User.IsInRole("Administrador"))
        {
            <div class="row g-4 mb-5">
                <div class="col-md-6 col-lg-3">
                    <div class="card metric-card border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #ec4899, #db2777);">
                        <div class="card-body text-center text-white">
                            <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                            <div class="icon-box mx-auto mb-3 position-relative">
                                <i class="bi bi-people"></i>
                            </div>
                            <h5 class="card-title mb-2 opacity-75">Clientes</h5>
                            <h2 class="fw-bold mb-3" style="font-size: 3rem;">@Model.TotalClientes</h2>
                            <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                                <div class="progress-bar" style="width: 75%; background: rgba(255,255,255,0.6);"></div>
                            </div>
                            <small class="text-white-50 mt-2 d-block">Registrados activos</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3">
                    <div class="card metric-card border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
                        <div class="card-body text-center text-white">
                            <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                            <div class="icon-box mx-auto mb-3 position-relative">
                                <i class="bi bi-cart-check"></i>
                            </div>
                            <h5 class="card-title mb-2 opacity-75">Pedidos</h5>
                            <h2 class="fw-bold mb-3" style="font-size: 3rem;">@Model.TotalPedidos</h2>
                            <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                                <div class="progress-bar" style="width: 90%; background: rgba(255,255,255,0.6);"></div>
                            </div>
                            <small class="text-white-50 mt-2 d-block">Total procesados</small>
                        </div>
                    </div>
                </div>

                <!-- MEDICAMENTOS ACTIVOS -->
                <div class="col-md-6 col-lg-3">
                    <div class="card metric-card border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                        <div class="card-body text-center text-white">
                            <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                            <div class="icon-box mx-auto mb-3 position-relative">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <h5 class="card-title mb-2 opacity-75">Medicamentos Activos</h5>
                            <h2 class="fw-bold mb-3" style="font-size: 3rem;">@Model.Disponibles.Count</h2>
                            <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                                <div class="progress-bar" style="width: 80%; background: rgba(255,255,255,0.6);"></div>
                            </div>
                            <small class="text-white-50 mt-2 d-block">Con stock disponible</small>
                        </div>
                    </div>
                </div>

                <!-- ALERTAS CRÍTICAS -->
                <div class="col-md-6 col-lg-3">
                    <div class="card metric-card border-0 rounded-4 h-100 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                        <div class="card-body text-center text-white">
                            <div class="position-absolute top-0 end-0" style="width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; transform: translate(50%, -50%);"></div>
                            <div class="icon-box mx-auto mb-3 position-relative">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                            <h5 class="card-title mb-2 opacity-75">Alertas Críticas</h5>
                            <h2 class="fw-bold mb-3" style="font-size: 3rem;">@(Model.Vencidos.Count + Model.StockBajo.Count)</h2>
                            <div class="progress" style="height: 4px; background: rgba(255,255,255,0.2);">
                                <div class="progress-bar" style="width: @((Model.Vencidos.Count + Model.StockBajo.Count) * 10)%; background: rgba(255,255,255,0.6);"></div>
                            </div>
                            <small class="text-white-50 mt-2 d-block">Requieren atención</small>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- SECCIÓN DE ALERTAS Y ESTADO MEJORADA -->
        <div class="row g-4 mb-4">
            <!-- MEDICAMENTOS VENCIDOS -->
            <div class="col-lg-4">
                <div class="card panel-card border-0 rounded-4 h-100 shadow-lg overflow-hidden">
                    <div class="card-header bg-danger text-white rounded-top-4 p-3 border-0 d-flex align-items-center justify-content-between">
                        <h5 class="mb-0 d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Medicamentos Vencidos
                        </h5>
                        @if (Model.Vencidos.Any())
                        {
                            <span class="badge bg-white text-danger">@Model.Vencidos.Count</span>
                        }
                    </div>
                    <div class="card-body">
                        @if (Model.Vencidos.Any())
                        {
                            <div class="alert alert-danger mb-3 d-flex align-items-center border-0" style="background: rgba(239, 68, 68, 0.1); color: #dc2626;">
                                <i class="bi bi-exclamation-circle me-2 fs-5"></i>
                                <strong>@Model.Vencidos.Count @(Model.Vencidos.Count == 1 ? "medicamento" : "medicamentos") vencido(s)</strong>
                            </div>
                            <div class="list-group list-group-flush">
                                @foreach (var item in Model.Vencidos.Take(5))
                                {
                                    <div class="list-group-item border-0 py-2 px-0 d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong class="text-danger d-block">@item.Nombre</strong>
                                            <small class="text-muted">Vence: @item.FechaVencimiento.ToString("dd/MM/yyyy")</small>
                                        </div>
                                        <span class="badge bg-danger ms-2">@item.Stock</span>
                                    </div>
                                }
                            </div>
                            @if (Model.Vencidos.Count > 5)
                            {
                                <small class="text-muted d-block mt-2 pt-2 border-top">+@(Model.Vencidos.Count - 5) más</small>
                            }
                        }
                        else
                        {
                            <div class="alert alert-success mb-0 d-flex align-items-center border-0">
                                <i class="bi bi-check-circle me-2 fs-5"></i>
                                <span>✓ No hay medicamentos vencidos</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- MEDICAMENTOS POR VENCER -->
            <div class="col-lg-4">
                <div class="card panel-card border-0 rounded-4 h-100 shadow-lg overflow-hidden">
                    <div class="card-header bg-warning text-dark rounded-top-4 p-3 border-0 d-flex align-items-center justify-content-between">
                        <h5 class="mb-0 d-flex align-items-center">
                            <i class="bi bi-clock-history me-2"></i>
                            Por Vencer (30 días)
                        </h5>
                        @if (Model.PorVencer.Any())
                        {
                            <span class="badge bg-dark">@Model.PorVencer.Count</span>
                        }
                    </div>
                    <div class="card-body">
                        @if (Model.PorVencer.Any())
                        {
                            <div class="alert alert-warning mb-3 d-flex align-items-center border-0" style="background: rgba(245, 158, 11, 0.1); color: #92400e;">
                                <i class="bi bi-exclamation-circle me-2 fs-5"></i>
                                <strong>@Model.PorVencer.Count @(Model.PorVencer.Count == 1 ? "medicamento" : "medicamentos") por vencer</strong>
                            </div>
                            <div class="list-group list-group-flush">
                                @foreach (var item in Model.PorVencer.Take(5))
                                {
                                    <div class="list-group-item border-0 py-2 px-0 d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong class="text-warning d-block">@item.Nombre</strong>
                                            <small class="text-muted">Vence: @item.FechaVencimiento.ToString("dd/MM/yyyy")</small>
                                        </div>
                                        <span class="badge bg-warning text-dark ms-2">@item.Stock</span>
                                    </div>
                                }
                            </div>
                            @if (Model.PorVencer.Count > 5)
                            {
                                <small class="text-muted d-block mt-2 pt-2 border-top">+@(Model.PorVencer.Count - 5) más</small>
                            }
                        }
                        else
                        {
                            <div class="alert alert-success mb-0 d-flex align-items-center border-0">
                                <i class="bi bi-check-circle me-2 fs-5"></i>
                                <span>✓ No hay medicamentos por vencer</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- STOCK BAJO -->
            <div class="col-lg-4">
                <div class="card panel-card border-0 rounded-4 h-100 shadow-lg overflow-hidden">
                    <div class="card-header bg-info text-white rounded-top-4 p-3 border-0 d-flex align-items-center justify-content-between">
                        <h5 class="mb-0 d-flex align-items-center">
                            <i class="bi bi-graph-down me-2"></i>
                            Stock Bajo (&lt;= 5)
                        </h5>
                        @if (Model.StockBajo.Any())
                        {
                            <span class="badge bg-white text-info">@Model.StockBajo.Count</span>
                        }
                    </div>
                    <div class="card-body">
                        @if (Model.StockBajo.Any())
                        {
                            <div class="alert alert-info mb-3 d-flex align-items-center border-0" style="background: rgba(6, 182, 212, 0.1); color: #0c5460;">
                                <i class="bi bi-exclamation-circle me-2 fs-5"></i>
                                <strong>@Model.StockBajo.Count @(Model.StockBajo.Count == 1 ? "medicamento" : "medicamentos") con stock bajo</strong>
                            </div>
                            <div class="list-group list-group-flush">
                                @foreach (var item in Model.StockBajo.Take(5))
                                {
                                    <div class="list-group-item border-0 py-2 px-0 d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong class="text-info d-block">@item.Nombre</strong>
                                            <small class="text-muted">@item.Categoria?.Nombre</small>
                                        </div>
                                        <span class="badge bg-danger ms-2">@item.Stock</span>
                                    </div>
                                }
                            </div>
                            @if (Model.StockBajo.Count > 5)
                            {
                                <small class="text-muted d-block mt-2 pt-2 border-top">+@(Model.StockBajo.Count - 5) más</small>
                            }
                        }
                        else
                        {
                            <div class="alert alert-success mb-0 d-flex align-items-center border-0">
                                <i class="bi bi-check-circle me-2 fs-5"></i>
                                <span>✓ Stock normal en todos los medicamentos</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- PEDIDOS RECIENTES (ADMIN) CON MEJORAS -->
        @if (User.IsInRole("Administrador") && Model.PedidosRecientes.Any())
        {
            <div class="row g-4 mt-4">
                <div class="col-12">
                    <div class="card panel-card border-0 rounded-4 shadow-lg overflow-hidden">
                        <div class="card-header text-white rounded-top-4 p-4 border-0" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                            <div class="d-flex align-items-center justify-content-between">
                                <h5 class="mb-0 d-flex align-items-center fs-5">
                                    <i class="bi bi-clock-history me-2"></i>
                                    Pedidos Recientes
                                </h5>
                                <span class="badge bg-white text-gradient">@Model.PedidosRecientes.Count</span>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead style="background: linear-gradient(90deg, #f3f4f6, #e5e7eb);">
                                        <tr>
                                            <th class="fw-bold">ID Pedido</th>
                                            <th class="fw-bold">Cliente</th>
                                            <th class="fw-bold">Fecha</th>
                                            <th class="fw-bold">Total</th>
                                            <th class="fw-bold">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var pedido in Model.PedidosRecientes.Take(5))
                                        {
                                            <tr>
                                                <td class="fw-bold text-gradient">#@pedido.Id</td>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="avatar-sm me-2" style="width: 32px; height: 32px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
                                                            @(pedido.Cliente?.Nombre?.FirstOrDefault().ToString().ToUpper() ?? "?")
                                                        </div>
                                                        <span>@(pedido.Cliente?.Nombre ?? "Sin cliente")</span>
                                                    </div>
                                                </td>
                                                <td>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    <span class="badge bg-success">Bs @pedido.Total.ToString("N2")</span>
                                                </td>
                                                <td>
                                                    <a asp-controller="Pedidos" asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-sm btn-primary">
                                                        <i class="bi bi-eye"></i> Ver Detalles
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (User.IsInRole("Cliente"))
    {
        <div class="text-center mb-5">
            <h1 class="page-title mb-3 display-4">Medicamentos Disponibles</h1>
            <p class="text-white fs-5">Consulta los productos disponibles en la farmacia</p>
        </div>

        @if (Model.Disponibles.Any())
        {
            <div class="row g-4">
                @foreach (var item in Model.Disponibles)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card panel-card h-100 border-0 rounded-4 shadow-lg">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h4 class="fw-bold text-gradient mb-0">@item.Nombre</h4>
                                    <span class="badge bg-success">Disponible</span>
                                </div>
                                <hr class="my-2">
                                <div class="mb-3">
                                    <p class="mb-2"><i class="bi bi-tag me-2 text-info"></i><strong>Categoría:</strong> @item.Categoria?.Nombre</p>
                                    <p class="mb-2"><i class="bi bi-inbox me-2 text-info"></i><strong>Estante:</strong> @item.Estante?.Nombre</p>
                                    <p class="mb-2"><i class="bi bi-cash-coin me-2 text-success"></i><strong>Precio:</strong> <span class="text-gradient fs-5">Bs @item.Precio</span></p>
                                    <p class="mb-3"><i class="bi bi-boxes me-2 text-warning"></i><strong>Stock:</strong> @item.Stock unidades</p>
                                </div>
                                <p class="text-muted small mb-3 fst-italic">@item.Descripcion</p>
                                <a href="#" class="btn btn-primary w-100">
                                    <i class="bi bi-cart-plus me-2"></i>Agregar al carrito
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-12">
                    <div class="card panel-card border-0 rounded-4 shadow-lg">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-inbox display-1 text-muted mb-3 d-block"></i>
                            <h4 class="text-muted mb-2">No hay medicamentos disponibles</h4>
                            <p class="text-muted">Por favor, intenta más tarde.</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>