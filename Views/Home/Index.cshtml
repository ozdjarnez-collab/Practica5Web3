@model Practica5Web3.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold text-primary">Dashboard de Farmacia</h1>
        <p class="text-muted">Resumen general del sistema</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow border-0 rounded-4 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">Total de Medicamentos</h5>
                    <h2 class="fw-bold">@Model.TotalMedicamentos</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success shadow border-0 rounded-4 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">Total de Categorías</h5>
                    <h2 class="fw-bold">@Model.TotalCategorias</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-dark shadow border-0 rounded-4 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">Total de Estantes</h5>
                    <h2 class="fw-bold">@Model.TotalEstantes</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow border-0 rounded-4 h-100">
                <div class="card-header bg-danger text-white rounded-top-4">
                    <h5 class="mb-0">Medicamentos Vencidos</h5>
                </div>
                <div class="card-body">
                    @if (Model.Vencidos.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.Vencidos)
                            {
                                <li class="list-group-item">
                                    <strong>@item.Nombre</strong><br />
                                    <small>Vence: @item.FechaVencimiento.ToString("dd/MM/yyyy")</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">No hay medicamentos vencidos.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow border-0 rounded-4 h-100">
                <div class="card-header bg-warning text-dark rounded-top-4">
                    <h5 class="mb-0">Medicamentos por Vencer</h5>
                </div>
                <div class="card-body">
                    @if (Model.PorVencer.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.PorVencer)
                            {
                                <li class="list-group-item">
                                    <strong>@item.Nombre</strong><br />
                                    <small>Vence: @item.FechaVencimiento.ToString("dd/MM/yyyy")</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">No hay medicamentos por vencer.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow border-0 rounded-4 h-100">
                <div class="card-header bg-info text-white rounded-top-4">
                    <h5 class="mb-0">Stock Bajo</h5>
                </div>
                <div class="card-body">
                    @if (Model.StockBajo.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.StockBajo)
                            {
                                <li class="list-group-item">
                                    <strong>@item.Nombre</strong><br />
                                    <small>Stock: @item.Stock</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">No hay medicamentos con stock bajo.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>