@model Practica5Web3.Models.Usuario

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Usuarios</a>

    <div class="card form-card">
        <div class="card-header">
            <h1>Nuevo Usuario y Perfil</h1>
        </div>

        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="validation-errors"></div>

                <div class="row">
                    <div class="col-md-6">
                        <h4 style="color: #667eea; margin-bottom: 1.5rem;">Datos de Cuenta</h4>
                        
                        <div class="form-group">
                            <label asp-for="Nombre" class="form-label"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan Pérez" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="Ej: juan@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h4 style="color: #667eea; margin-bottom: 1.5rem;">Detalles del Perfil</h4>
                        
                        <div class="form-group">
                            <label asp-for="Perfil.Direccion" class="form-label"></label>
                            <input asp-for="Perfil.Direccion" class="form-control" placeholder="Ej: Calle Principal 123" />
                            <span asp-validation-for="Perfil.Direccion" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Perfil.Telefono" class="form-label"></label>
                            <input asp-for="Perfil.Telefono" class="form-control" placeholder="Ej: +591 70000000" />
                            <span asp-validation-for="Perfil.Telefono" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Perfil.FechaNacimiento" class="form-label"></label>
                            <input asp-for="Perfil.FechaNacimiento" type="date" class="form-control" />
                            <span asp-validation-for="Perfil.FechaNacimiento" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Crear Usuario
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}