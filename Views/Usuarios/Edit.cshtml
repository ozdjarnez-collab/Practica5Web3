@model Practica5Web3.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario y Perfil";
}

<h1>Editar Usuario</h1>

<h4>Gestión de Información Personal</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <h5>Datos de Cuenta</h5>
            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label fw-bold"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label fw-bold"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <h5 class="mt-4">Datos del Perfil (Fernando)</h5>
            <hr />
            @* Importante: Campo oculto para mantener la relación *@
            <input type="hidden" asp-for="Perfil.UsuarioId" />

            <div class="form-group mb-3">
                <label asp-for="Perfil.Direccion" class="control-label"></label>
                <input asp-for="Perfil.Direccion" class="form-control" />
                <span asp-validation-for="Perfil.Direccion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Perfil.Telefono" class="control-label"></label>
                <input asp-for="Perfil.Telefono" class="form-control" />
                <span asp-validation-for="Perfil.Telefono" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Perfil.FechaNacimiento" class="control-label"></label>
                <input asp-for="Perfil.FechaNacimiento" type="date" class="form-control" />
                <span asp-validation-for="Perfil.FechaNacimiento" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}