@model Practica5Web3.Models.Usuario

@{
    ViewData["Title"] = "Detalles de Usuario";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Usuarios</a>

    <div class="card details-card">
        <div class="details-header">
            <h1>Detalles de Usuario</h1>
        </div>

        <div class="details-body">
            <div class="details-section">
                <h3>Información de Cuenta</h3>
                
                <div class="details-row">
                    <div class="details-label">Nombre</div>
                    <div class="details-value fw-semibold">@Html.DisplayFor(model => model.Nombre)</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Email</div>
                    <div class="details-value">@Html.DisplayFor(model => model.Email)</div>
                </div>
            </div>

            @if (Model.Perfil != null)
            {
                <div class="details-section">
                    <h3>Información del Perfil</h3>
                    
                    <div class="details-row">
                        <div class="details-label">Dirección</div>
                        <div class="details-value">@Model.Perfil.Direccion</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Teléfono</div>
                        <div class="details-value">@Model.Perfil.Telefono</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Fecha de Nacimiento</div>
                        <div class="details-value">@Model.Perfil.FechaNacimiento.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
            }

            <div class="details-actions">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Editar
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-list"></i> Volver al Listado
                </a>
            </div>
        </div>
    </div>
</div>
