@model IEnumerable<Practica5Web3.Models.Usuario>

@{
    ViewData["Title"] = "Lista de Usuarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Gestión de Usuarios</h1>
        <a asp-action="Create" class="btn btn-primary">Crear Nuevo Usuario</a>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="thead-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                <th>@Html.DisplayNameFor(model => model.Email)</th>
                <th>Teléfono (Perfil)</th>
                <th>Dirección</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                    <td>@Html.DisplayFor(modelItem => item.Email)</td>
                    <td>@(item.Perfil?.Telefono ?? "N/A")</td>
                    <td>@(item.Perfil?.Direccion ?? "Sin dirección")</td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning text-white">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info text-white">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Eliminar</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>