@model Practica5Web3.Models.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Clientes</a>

    <div class="card details-card">
        <div class="details-header">
            <h1>Información del Cliente</h1>
        </div>

        <div class="details-body">
            <div class="details-section">
                <h3>Datos Generales</h3>
                
                <div class="details-row">
                    <div class="details-label">Nombre</div>
                    <div class="details-value fw-semibold">@Html.DisplayFor(model => model.Nombre)</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Email</div>
                    <div class="details-value">@Html.DisplayFor(model => model.Email)</div>
                </div>
            </div>

            @if (Model.Pedidos != null && Model.Pedidos.Any())
            {
                <div class="details-section">
                    <h3>Historial de Pedidos</h3>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>ID Pedido</th>
                                    <th>Fecha</th>
                                    <th>Monto Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pedido in Model.Pedidos)
                                {
                                    <tr>
                                        <td class="fw-semibold">@pedido.Id</td>
                                        <td>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge bg-success">@pedido.Total.ToString("C")</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="details-actions">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Editar
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-list"></i> Volver al Listado
                </a>
            </div>
        </div>
    </div>
</div>