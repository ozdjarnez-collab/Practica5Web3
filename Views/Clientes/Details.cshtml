@model Practica5Web3.Models.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container mt-4">
    <h1>Información del Cliente</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="card-title">Datos Generales</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3 font-weight-bold">@Html.DisplayNameFor(model => model.Nombre)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Nombre)</dd>

                <dt class="col-sm-3 font-weight-bold">@Html.DisplayNameFor(model => model.Email)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="card-title text-primary">Historial de Pedidos</h4>
            <hr />
            @if (Model.Pedidos != null && Model.Pedidos.Any())
            {
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID Pedido</th>
                            <th>Fecha</th>
                            <th>Monto Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pedido in Model.Pedidos)
                        {
                            <tr>
                                <td>@pedido.Id</td>
                                <td>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-success fw-bold">@pedido.Total.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">Este cliente aún no tiene pedidos registrados.</div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
    </div>
</div>