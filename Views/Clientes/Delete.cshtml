@model Practica5Web3.Models.Cliente

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Clientes</a>

    <div class="card delete-card">
        <div class="card-header">
            <h1>Eliminar Cliente</h1>
        </div>

        <div class="card-body">
            <div class="delete-warning">
                <div class="delete-warning-icon">⚠️</div>
                <div>
                    ¿Estás seguro de que deseas eliminar este cliente? Esta acción no se puede deshacer.
                </div>
            </div>

            <div class="details-section">
                <h3 style="color: #1f2937; margin-bottom: 1.5rem;">Información del Cliente</h3>
                
                <div class="details-row">
                    <div class="details-label">Nombre</div>
                    <div class="details-value fw-semibold">@Html.DisplayFor(model => model.Nombre)</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Email</div>
                    <div class="details-value">@Html.DisplayFor(model => model.Email)</div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="delete-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3"></i> Confirmar Eliminación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
