@model IEnumerable<Practica5Web3.Models.Medicamento>

@{
    ViewData["Title"] = "Medicamentos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title mb-1">Medicamentos</h1>
            <p class="text-muted mb-0">Inventario general de medicamentos</p>
        </div>

        @if (User.IsInRole("Administrador") || User.IsInRole("Farmaceutico"))
        {
            <a asp-action="Create" class="btn btn-dark">
                + Nuevo medicamento
            </a>
        }
    </div>

    <!-- Buscador -->
    <div class="card panel-card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="d-flex gap-2">
                <input type="text" name="search" class="form-control" placeholder="Buscar por nombre, categoría o descripción..." value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Buscar
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                }
            </form>
        </div>
    </div>

    @if (ViewBag.SearchTerm != null && !string.IsNullOrEmpty(ViewBag.SearchTerm))
    {
        <div class="alert alert-info mb-3">
            Resultados de búsqueda para: <strong>@ViewBag.SearchTerm</strong>
        </div>
    }

    <div class="card panel-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Vencimiento</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                            <th>Categoría</th>
                            <th>Estante</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Nombre</td>
                                <td>Bs @item.Precio</td>
                                <td>
                                    @if (item.Stock <= 5)
                                    {
                                        <span class="badge bg-danger">@item.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@item.Stock</span>
                                    }
                                </td>
                                <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                                <td>@item.Descripcion</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge bg-primary">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td>@item.Categoria?.Nombre</td>
                                <td>@item.Estante?.Nombre</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">Detalles</a>

                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">Editar</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="p-4 text-center text-muted">
                    <p class="mb-0">No hay medicamentos disponibles</p>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <p class="small">Intenta con otros términos de búsqueda</p>
                    }
                </div>
            }
        </div>
    </div>
</div>