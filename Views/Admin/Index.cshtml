@{
    ViewData["Title"] = "Panel de Administrador";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="page-title display-5">Panel de Administrador</h1>
        <p class="section-subtitle">Control total del sistema de farmacia</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card panel-card h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-primary text-white mx-auto">📂</div>
                    <h4>Categorías</h4>
                    <p class="text-muted">Administra las categorías de medicamentos.</p>
                    <a asp-controller="Categorias" asp-action="Index" class="btn btn-primary w-100">Ir a Categorías</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card panel-card h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-success text-white mx-auto">🗂️</div>
                    <h4>Estantes</h4>
                    <p class="text-muted">Gestiona los estantes y ubicaciones físicas.</p>
                    <a asp-controller="Estantes" asp-action="Index" class="btn btn-success w-100">Ir a Estantes</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card panel-card h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-dark text-white mx-auto">💊</div>
                    <h4>Medicamentos</h4>
                    <p class="text-muted">Consulta y administra todo el inventario.</p>
                    <a asp-controller="Medicamentoes" asp-action="Index" class="btn btn-dark w-100">Ir a Medicamentos</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card panel-card h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-warning text-dark mx-auto">📊</div>
                    <h4>Dashboard</h4>
                    <p class="text-muted">Visualiza el resumen general del sistema.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-warning w-100">Ver Dashboard</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card panel-card h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-info text-white mx-auto">🛡️</div>
                    <h4>Acceso Administrativo</h4>
                    <p class="text-muted">Este panel está disponible solo para el Administrador.</p>
                    <button class="btn btn-info w-100" disabled>Acceso Exclusivo</button>
                </div>
            </div>
        </div>
    </div>
</div>