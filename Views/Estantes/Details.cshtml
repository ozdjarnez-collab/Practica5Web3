@model Practica5Web3.Models.Estante

@{
    ViewData["Title"] = "Detalles de Estante";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Estantes</a>

    <div class="card details-card">
        <div class="details-header">
            <h1>Detalles de Estante</h1>
        </div>

        <div class="details-body">
            <div class="details-section">
                <div class="details-row">
                    <div class="details-label">Nombre</div>
                    <div class="details-value fw-semibold">@Html.DisplayFor(model => model.Nombre)</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Ubicación</div>
                    <div class="details-value">@Html.DisplayFor(model => model.Ubicacion)</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Descripción</div>
                    <div class="details-value">@Html.DisplayFor(model => model.Descripcion)</div>
                </div>
            </div>

            <div class="details-actions">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Editar
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-list"></i> Volver al Listado
                </a>
            </div>
        </div>
    </div>
</div>
