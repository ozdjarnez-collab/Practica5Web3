@model Practica5Web3.Models.Categoria

@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Categorías</a>

    <div class="card form-card">
        <div class="card-header">
            <h1>Nueva Categoría</h1>
        </div>

        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="validation-errors"></div>

                <div class="form-group">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Analgésicos" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <input asp-for="Descripcion" class="form-control" placeholder="Ej: Medicamentos para el dolor" />
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Crear Categoría
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
