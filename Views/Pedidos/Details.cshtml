@model Practica5Web3.Models.Pedido

@{
    ViewData["Title"] = "Detalles del Pedido";
}

<div class="container mt-4">
    <h1>Detalles del Pedido</h1>

    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">Pedido #@Model.Id</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Fecha de Registro</dt>
                <dd class="col-sm-9">@Model.FechaPedido.ToString("f")</dd>

                <dt class="col-sm-3">Monto Total</dt>
                <dd class="col-sm-9 text-success fw-bold">@Model.Total.ToString("C")</dd>

                <dt class="col-sm-3">Cliente</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Cliente.Nombre)</dd>

                <dt class="col-sm-3">Email Cliente</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Cliente.Email)</dd>
            </dl>
        </div>
        <div class="card-footer">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
        </div>
    </div>
</div>