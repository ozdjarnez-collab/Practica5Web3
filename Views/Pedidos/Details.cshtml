@model Practica5Web3.Models.Pedido

@{
    ViewData["Title"] = "Detalles del Pedido";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Pedidos</a>

    <div class="card details-card">
        <div class="details-header">
            <h1>Detalles del Pedido #@Model.Id</h1>
        </div>

        <div class="details-body">
            <div class="details-section">
                <h3>Información del Pedido</h3>
                
                <div class="details-row">
                    <div class="details-label">Fecha de Registro</div>
                    <div class="details-value">@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Monto Total</div>
                    <div class="details-value">
                        <span class="badge bg-success" style="font-size: 1rem;">@Model.Total.ToString("C")</span>
                    </div>
                </div>
            </div>

            <div class="details-section">
                <h3>Información del Cliente</h3>
                
                <div class="details-row">
                    <div class="details-label">Nombre</div>
                    <div class="details-value fw-semibold">@Html.DisplayFor(model => model.Cliente.Nombre)</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Email</div>
                    <div class="details-value">@Html.DisplayFor(model => model.Cliente.Email)</div>
                </div>
            </div>

            @if (Model.PedidoMedicamentos != null && Model.PedidoMedicamentos.Any())
            {
                <div class="details-section">
                    <h3>Medicamentos en este Pedido</h3>
                    
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Medicamento</th>
                                    <th>Cantidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.PedidoMedicamentos)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.Medicamento.Nombre</td>
                                        <td>
                                            <span class="badge bg-primary">@item.Cantidad unidades</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="details-actions">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Editar
                </a>
                <a asp-controller="PedidoMedicamentos" asp-action="Create" asp-route-pedidoId="@Model.Id" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Agregar Medicamento
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-list"></i> Volver al Listado
                </a>
            </div>
        </div>
    </div>
</div>