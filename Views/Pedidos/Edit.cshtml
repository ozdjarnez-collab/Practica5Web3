@model Practica5Web3.Models.Pedido

@{
    ViewData["Title"] = "Editar Pedido";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Pedidos</a>

    <div class="card form-card">
        <div class="card-header">
            <h1>Editar Pedido</h1>
        </div>

        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="validation-errors"></div>
                
                <input type="hidden" asp-for="Id" />

                <div class="form-group">
                    <label asp-for="FechaPedido" class="form-label"></label>
                    <input asp-for="FechaPedido" class="form-control" type="datetime-local" />
                    <span asp-validation-for="FechaPedido" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Total" class="form-label"></label>
                    <input asp-for="Total" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Total" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ClienteId" class="form-label"></label>
                    <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId"></select>
                    <span asp-validation-for="ClienteId" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-check-circle"></i> Guardar Cambios
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
