@model Practica5Web3.Models.Pedido

@{
    ViewData["Title"] = "Eliminar Pedido";
}

<div class="container mt-4">
    <a asp-action="Index" class="back-link">Volver a Pedidos</a>

    <div class="card delete-card">
        <div class="card-header">
            <h1>Eliminar Pedido</h1>
        </div>

        <div class="card-body">
            <div class="delete-warning">
                <div class="delete-warning-icon">⚠️</div>
                <div>
                    ¿Estás seguro de que deseas eliminar este pedido? Esta acción no se puede deshacer.
                </div>
            </div>

            <div class="details-section">
                <h3 style="color: #1f2937; margin-bottom: 1.5rem;">Información del Pedido</h3>
                
                <div class="details-row">
                    <div class="details-label">Número de Pedido</div>
                    <div class="details-value fw-semibold">#@Model.Id</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Fecha del Pedido</div>
                    <div class="details-value">@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Monto Total</div>
                    <div class="details-value">@Model.Total.ToString("C")</div>
                </div>

                <div class="details-row">
                    <div class="details-label">Cliente</div>
                    <div class="details-value fw-semibold">@Html.DisplayFor(model => model.Cliente.Nombre)</div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="delete-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3"></i> Confirmar Eliminación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
